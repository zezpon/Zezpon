PORT=3000
NODE_ENV=production
PUBLIC_BASE_URL=https://zezpon.com
ZEZPON_DATA_DIR=/var/lib/zezpon

ZEZPON_ADMIN_NAME=Zezpon Admin
ZEZPON_ADMIN_USERNAME=zezponadmin
ZEZPON_ADMIN_EMAIL=admin@zezpon.com
ZEZPON_ADMIN_PASSWORD=ChangeThisStrongPassword123!

MAIL_FROM=no-reply@zezpon.com
SMTP_HOST=smtp.postmarkapp.com
SMTP_PORT=587
SMTP_USER=postmark-server-token
SMTP_PASS=postmark-server-token
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true

STORAGE_PROVIDER=s3
STORAGE_BUCKET=zezpon-media
STORAGE_REGION=ap-southeast-2
STORAGE_ENDPOINT=
STORAGE_PUBLIC_BASE_URL=https://media.zezpon.com
STORAGE_ACCESS_KEY_ID=replace-me
STORAGE_SECRET_ACCESS_KEY=replace-me
STORAGE_FORCE_PATH_STYLE=false

SHOW_DEBUG_TOKENS=false
