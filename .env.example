PORT=3000
NODE_ENV=production
ZEZPON_DATA_DIR=./runtime-data
ZEZPON_ADMIN_NAME=Zezpon Admin
ZEZPON_ADMIN_EMAIL=admin@example.com
ZEZPON_ADMIN_PASSWORD=ChangeThisStrongPassword123!
PUBLIC_BASE_URL=https://your-domain.example
MAIL_FROM=no-reply@your-domain.example
SMTP_HOST=smtp.your-provider.example
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
STORAGE_PROVIDER=local
STORAGE_BUCKET=
STORAGE_REGION=
STORAGE_ENDPOINT=
STORAGE_PUBLIC_BASE_URL=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_FORCE_PATH_STYLE=false
SHOW_DEBUG_TOKENS=false
BILLING_PROVIDER=hosted-links
BASIC_PLAN_PRICE_LABEL=$12/month
PREMIUM_PLAN_PRICE_LABEL=$24/month
BASIC_PLAN_CHECKOUT_URL=
PREMIUM_PLAN_CHECKOUT_URL=
